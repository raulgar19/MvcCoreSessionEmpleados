@{
    List<Empleado> favoritos = memoryCache.Get<List<Empleado>>("FAVORITOS");
}

<h1>Empleados favoritos</h1>

<p>
    <a asp-controller="Empleados" asp-action="SessionEmpleadosV5">Volver a empleados V5</a>
</p>

@if (favoritos == null)
{
    <h3 style="color:red">No tenemos empleados favoritos</h3>
}
else
{
    <table class="table table-warning">
        <thead>
            <tr>
                <th>Apellido</th>
                <th>Oficio</th>
                <th>Salario</th>
                <th>Departamento</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in favoritos)
            {
                <tr>
                    <td>@item.Apellido</td>
                    <td>@item.Oficio</td>
                    <td>@item.Salario</td>
                    <td>@item.IdDepartamento</td>
                    <td>
                        <a asp-controller="Empleados" asp-action="EmpleadosFavoritos" asp-route-ideliminar="@item.IdEmpleado" class="btn btn-warning">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}