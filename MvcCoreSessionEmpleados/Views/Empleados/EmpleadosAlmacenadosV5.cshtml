@model List<Empleado>

<h1 style="color:darkred">
    Empleados almacenados V5
</h1>
<p>
    <a asp-controller="Empleados"
       asp-action="SessionEmpleadosV5">
        Volver a empleados
    </a>
</p>

@if(Context.Session.GetString("IDSEMPLEADOS") == null)
{
    <h1 style="color:red">No existen empleaos en Session</h1>
}

@if (Model != null)
{
    <table class="table table-warning">
        <thead>
            <tr>
                <th>Id</th>
                <th>Apellido</th>
                <th>Oficio</th>
                <th>Salario</th>
                <th>Departamento</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.IdEmpleado</td>
                    <td>@item.Apellido</td>
                    <td>@item.Oficio</td>
                    <td>@item.Salario</td>
                    <td>@item.IdDepartamento</td>
                    <td>
                        <a asp-controller="Empleados"
                           asp-action="EmpleadosAlmacenadosV5" class="btn btn-outline-danger"
                           asp-route-ideliminar="@item.IdEmpleado">
                            Eliminar session
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}