@model List<Empleado>

<h1 style="color:blue">Empleados Session OK</h1>

<p>
    <a asp-controller="Empleados" asp-action="EmpleadosAlmacenadosOk">Empleados almacenados</a>
</p>

<h2 style="color:green">@ViewData["MENSAJE"]</h2>

<ul class="list-group">
    @foreach (Empleado empleado in Model)
    {
        <li class="list-group-item list-group-item-danger">
            @empleado.Apellido
            <a class="btn btn-warning" asp-controller="Empleados" asp-action="SessionEmpleadosOk" asp-route-idempleado="@empleado.IdEmpleado">Almacenar empleado</a>
        </li>
    }
</ul>